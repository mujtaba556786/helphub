<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog id="dmChatDialog" title="{i18n>messages}" contentHeight="65vh" contentWidth="92%" verticalScrolling="false" stretch="{device>/system/phone}">
        <VBox height="100%" class="hhChatLayout">
            <ScrollContainer id="dmScrollContainer" vertical="true" horizontal="false" class="hhChatMessages">
                <core:HTML id="dmBubblesHtml" content="&lt;div&gt;&lt;/div&gt;"/>
            </ScrollContainer>
            <HBox class="hhQuickReplies" wrap="Wrap">
                <Button text="{i18n>qrOnMyWay}"          type="Transparent" press="onDmQuickReply" class="hhQRChip sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
                <Button text="{i18n>qrImAvailable}"      type="Transparent" press="onDmQuickReply" class="hhQRChip sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
                <Button text="{i18n>qrReschedule}"       type="Transparent" press="onDmQuickReply" class="hhQRChip sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
                <Button text="{i18n>qrThankYou}"         type="Transparent" press="onDmQuickReply" class="hhQRChip sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
                <Button text="{i18n>qrSeeSoon}"          type="Transparent" press="onDmQuickReply" class="hhQRChip sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
            </HBox>
            <HBox alignItems="Center" class="hhChatInputBar">
                <Input id="dmInput" placeholder="{i18n>typeMessage}" width="100%" submit="onDmSend"/>
                <Button id="dmSendBtn" icon="sap-icon://paper-plane" type="Emphasized" press="onDmSend" class="sapUiTinyMarginBegin"/>
            </HBox>
        </VBox>
        <endButton>
            <Button text="{i18n>close}" press="onCloseDmChat"/>
        </endButton>
    </Dialog>

</core:FragmentDefinition>
