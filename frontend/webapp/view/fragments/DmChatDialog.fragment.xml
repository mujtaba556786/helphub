<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog id="dmChatDialog" title="{appData>/currentDmOtherName}"
        contentHeight="65vh" contentWidth="92%"
        verticalScrolling="false"
        stretch="{device>/system/phone}">

        <customHeader>
            <Bar>
                <contentLeft>
                    <Button icon="sap-icon://nav-back" type="Transparent" press="onCloseDmChat"/>
                </contentLeft>
                <contentMiddle>
                    <Title text="{appData>/currentDmOtherName}"/>
                </contentMiddle>
                <contentRight>
                    <Button icon="sap-icon://decline" tooltip="Close" type="Transparent" press="onCloseDmChat"/>
                </contentRight>
            </Bar>
        </customHeader>

        <!-- Quick replies pinned below header -->
        <subHeader>
            <Bar>
                <contentLeft>
                    <HBox wrap="Wrap" alignItems="Center" class="sapUiTinyMarginBeginEnd sapUiTinyMarginTopBottom">
                        <Button icon="sap-icon://car-rental"    text="{i18n>qrOnMyWay}"     type="Transparent" press="onDmQuickReply" class="hhQRChip sapUiTinyMarginEnd"/>
                        <Button icon="sap-icon://accept"        text="{i18n>qrImAvailable}" type="Transparent" press="onDmQuickReply" class="hhQRChip sapUiTinyMarginEnd"/>
                        <Button icon="sap-icon://appointment-2" text="{i18n>qrReschedule}"  type="Transparent" press="onDmQuickReply" class="hhQRChip sapUiTinyMarginEnd"/>
                        <Button icon="sap-icon://heart"         text="{i18n>qrThankYou}"    type="Transparent" press="onDmQuickReply" class="hhQRChip sapUiTinyMarginEnd"/>
                        <Button icon="sap-icon://goodbye"       text="{i18n>qrSeeSoon}"     type="Transparent" press="onDmQuickReply" class="hhQRChip sapUiTinyMarginEnd"/>
                    </HBox>
                </contentLeft>
            </Bar>
        </subHeader>

        <!-- Messages area fills remaining space -->
        <content>
            <ScrollContainer id="dmScrollContainer" height="100%" vertical="true" horizontal="false">
                <core:HTML id="dmBubblesHtml" content="&lt;div&gt;&lt;/div&gt;"/>
            </ScrollContainer>
        </content>

        <!-- Input bar pinned to bottom -->
        <footer>
            <Bar>
                <contentLeft>
                    <Input id="dmInput" placeholder="{i18n>typeMessage}" submit="onDmSend"/>
                </contentLeft>
                <contentRight>
                    <Button id="dmSendBtn" icon="sap-icon://paper-plane" type="Emphasized" press="onDmSend"/>
                </contentRight>
            </Bar>
        </footer>

    </Dialog>

</core:FragmentDefinition>
