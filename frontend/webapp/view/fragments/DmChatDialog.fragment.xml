<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog id="dmChatDialog" title="{appData>/currentDmOtherName}"
        verticalScrolling="false"
        stretch="{device>/system/phone}">

        <customHeader>
            <Bar>
                <contentLeft>
                    <Button icon="sap-icon://nav-back" type="Transparent" press="onCloseDmChat"/>
                </contentLeft>
                <contentMiddle>
                    <Title text="{appData>/currentDmOtherName}"/>
                </contentMiddle>
                <contentRight>
                    <Button icon="sap-icon://decline" tooltip="Close" type="Transparent" press="onCloseDmChat"/>
                </contentRight>
            </Bar>
        </customHeader>

<content>
            <FlexBox direction="Column" height="100%" fitContainer="true">
                <items>
                    <!-- Messages — grows to fill -->
                    <ScrollContainer id="dmScrollContainer" vertical="true" horizontal="false">
                        <layoutData><FlexItemData growFactor="1" shrinkFactor="1" baseSize="0"/></layoutData>
                        <core:HTML id="dmBubblesHtml" content="&lt;div&gt;&lt;/div&gt;"/>
                    </ScrollContainer>
                    <!-- Input bar — pinned to bottom -->
                    <HBox alignItems="Center" class="sapUiSmallMarginBeginEnd sapUiTinyMarginBottom">
                        <layoutData><FlexItemData shrinkFactor="0"/></layoutData>
                        <Input id="dmInput" placeholder="{i18n>typeMessage}" width="100%" submit="onDmSend"/>
                        <Button id="dmSendBtn" icon="sap-icon://paper-plane" type="Emphasized" press="onDmSend" class="sapUiTinyMarginBegin"/>
                    </HBox>
                </items>
            </FlexBox>
        </content>

    </Dialog>

</core:FragmentDefinition>
