<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog id="bookingDialog" title="{i18n>bookAHelper}"
        contentWidth="90%"
        stretch="true">

        <!-- Helper name pinned below header, never hidden -->
        <subHeader>
            <Bar>
                <contentLeft>
                    <Title text="{appData>/selectedProfile/name}" level="H5" class="sapUiTinyMarginBegin"/>
                </contentLeft>
            </Bar>
        </subHeader>

        <content>
            <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom">
                <Label text="{i18n>service}" required="true"/>
                <Text text="{appData>/selectedProfile/serviceType}" class="fontBold sapUiTinyMarginBottom"/>
                <Label text="{i18n>preferredDate}" required="true"/>
                <DatePicker id="bookingDate" value="{appData>/bookingForm/date}" valueFormat="yyyy-MM-dd" displayFormat="MMM dd, yyyy" width="100%" class="sapUiTinyMarginBottom"/>
                <Label text="{i18n>preferredTime}"/>
                <Input id="bookingTime" value="{appData>/bookingForm/time}" placeholder="{i18n>timePlaceholder}" width="100%" class="sapUiTinyMarginBottom"/>
                <Label text="{i18n>messageToHelper}"/>
                <TextArea value="{appData>/bookingForm/message}" rows="3" width="100%" placeholder="{i18n>describeNeedPlaceholder}"/>
            </VBox>
        </content>

        <beginButton>
            <Button text="{i18n>sendBookingRequest}" type="Emphasized" press="onConfirmBooking"/>
        </beginButton>
        <endButton>
            <Button text="{i18n>cancel}" press="onCloseBooking"/>
        </endButton>

    </Dialog>

</core:FragmentDefinition>
