<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Dialog id="profileDialog"
        title="{appData>/selectedProfile/name}"
        verticalScrolling="true"
        stretch="{device>/system/phone}">

        <content>
            <VBox>

                <!-- ── Hero ── -->
                <HBox alignItems="Center"
                    class="sapUiMediumMarginBeginEnd sapUiMediumMarginTop sapUiSmallMarginBottom">
                    <Avatar
                        src="{appData>/selectedProfile/photo}"
                        initials="{appData>/selectedProfile/initials}"
                        displaySize="L"
                        class="sapUiMediumMarginEnd"/>
                    <VBox>
                        <Text text="{appData>/selectedProfile/serviceType}" class="smallText"/>
                        <HBox alignItems="Center" class="sapUiTinyMarginTop">
                            <RatingIndicator value="{appData>/selectedProfile/rating}" maxValue="5" visualMode="Half" displayOnly="true" class="sapUiTinyMarginEnd"/>
                            <Text text="{= ${appData>/selectedProfile/rating} ? String(${appData>/selectedProfile/rating}) + ' / 5' : 'No rating'}" class="smallText"/>
                        </HBox>
                        <ObjectStatus
                            text="{= ${appData>/selectedProfile/trust_level} === 'trusted_user' ? 'Trusted User' : ${appData>/selectedProfile/trust_level} === 'verified_user' ? 'Verified User' : 'New User' }"
                            state="{= ${appData>/selectedProfile/trust_level} === 'trusted_user' ? 'Success' : ${appData>/selectedProfile/trust_level} === 'verified_user' ? 'Information' : 'None' }"
                            visible="{= !!${appData>/selectedProfile/trust_level} }"
                            class="sapUiTinyMarginTop"/>
                    </VBox>
                </HBox>

                <!-- ── Action buttons (only for other people) ── -->
                <HBox justifyContent="SpaceAround"
                    class="sapUiMediumMarginBeginEnd sapUiSmallMarginBottom"
                    visible="{= String(${appData>/selectedProfile/id}) !== String(${appData>/user/id})}">
                    <Button text="Book"    icon="sap-icon://appointment-2" type="Emphasized" press="onOpenBooking"/>
                    <Button text="Message" icon="sap-icon://discussion"    type="Default"    press="onStartDm"/>
                    <Button text="Ask AI"  icon="sap-icon://da"            type="Default"    press="onOpenChat"/>
                </HBox>

                <!-- ── Edit Profile shortcut (only for own profile) ── -->
                <HBox justifyContent="Center"
                    class="sapUiMediumMarginBeginEnd sapUiSmallMarginBottom"
                    visible="{= String(${appData>/selectedProfile/id}) === String(${appData>/user/id})}">
                    <Button text="{i18n>editProfile}" icon="sap-icon://edit" type="Emphasized"
                        press="onEditProfileFromDialog" width="100%"/>
                </HBox>

                <!-- ── Info rows — SAP UI5 StandardListItem: icon | label | value ── -->
                <List showSeparators="Inner" class="sapUiSmallMarginBottom">
                    <StandardListItem
                        icon="sap-icon://money-bills"
                        title="Rate"
                        info="{= ${appData>/selectedProfile/rate} ? ${appData>/selectedProfile/rate} + ' ' + (${appData>/selectedProfile/currency} || 'EUR') + '/hr' : '—'}"
                        type="Inactive"/>
                    <StandardListItem
                        icon="sap-icon://history"
                        title="Experience"
                        info="{= ${appData>/selectedProfile/years} ? ${appData>/selectedProfile/years} + ' years' : '—'}"
                        type="Inactive"/>
                    <StandardListItem
                        icon="sap-icon://world"
                        title="Language"
                        info="{= ${appData>/selectedProfile/languages} || '—'}"
                        type="Inactive"/>
                    <StandardListItem
                        icon="sap-icon://map"
                        title="Location"
                        info="{= ${appData>/selectedProfile/city} || '—'}"
                        type="Inactive"
                        wrapping="true"/>
                </List>

                <!-- ── Bio ── -->
                <VBox class="sapUiMediumMarginBeginEnd sapUiSmallMarginTop sapUiSmallMarginBottom">
                    <Title text="About" level="H5" class="sapUiTinyMarginBottom"/>
                    <Text text="{= ${appData>/selectedProfile/bio} || 'No bio added yet.'}" wrapping="true"/>
                </VBox>

                <!-- ── Reviews ── -->
                <VBox class="sapUiMediumMarginBeginEnd sapUiSmallMarginTop">
                    <Title text="{i18n>reviews}" level="H5" class="sapUiTinyMarginBottom"/>
                    <List id="reviewsList"
                        items="{appData>/selectedProfile/reviews}"
                        noDataText="{i18n>noReviewsYet}"
                        showSeparators="None">
                        <CustomListItem>
                            <HBox alignItems="Start" class="sapUiTinyMarginTopBottom">
                                <Avatar initials="{appData>reviewer_initials}" displaySize="XS" class="sapUiSmallMarginEnd"/>
                                <VBox width="100%">
                                    <HBox justifyContent="SpaceBetween" alignItems="Center">
                                        <Text text="{appData>reviewer_name}" class="fontBold smallText"/>
                                        <RatingIndicator value="{appData>stars}" maxValue="5" displayOnly="true" iconSize="12px"/>
                                    </HBox>
                                    <Text text="{appData>created_at_relative}" class="smallText grayText"/>
                                    <Text text="{appData>comment}" wrapping="true" class="smallText"/>
                                </VBox>
                            </HBox>
                        </CustomListItem>
                    </List>

                    <!-- Leave a review — only for other people -->
                    <Panel
                        headerText="{i18n>rateThisHelper}"
                        class="sapUiSmallMarginTop"
                        visible="{= String(${appData>/selectedProfile/id}) !== String(${appData>/user/id})}">
                        <content>
                            <VBox class="sapUiSmallMarginBeginEnd sapUiSmallMarginTopBottom">
                                <Label text="{i18n>yourRating}" required="true" class="sapUiTinyMarginBottom"/>
                                <RatingIndicator id="newRatingStars" maxValue="5" value="0" class="sapUiTinyMarginBottom"/>
                                <Label text="{i18n>yourComment}" class="sapUiTinyMarginBottom"/>
                                <TextArea id="newRatingComment" rows="3" width="100%" placeholder="{i18n>ratingPlaceholder}" class="sapUiTinyMarginBottom"/>
                                <Button text="{i18n>submitRating}" type="Emphasized" icon="sap-icon://paper-plane" press="onSubmitRating" width="100%"/>
                            </VBox>
                        </content>
                    </Panel>
                </VBox>

                <!-- ── Safety (only for other people) ── -->
                <VBox class="sapUiMediumMarginBeginEnd sapUiSmallMarginTop sapUiSmallMarginBottom"
                    visible="{= String(${appData>/selectedProfile/id}) !== String(${appData>/user/id})}">
                    <Text text="Use these options if you feel unsafe or this user is behaving inappropriately."
                        wrapping="true" class="smallText sapUiSmallMarginBottom"/>
                    <HBox>
                        <Button text="Block User"  type="Reject" icon="sap-icon://cancel" press="onBlockUser"  class="sapUiSmallMarginEnd"/>
                        <Button text="Report User" type="Ghost"  icon="sap-icon://flag"   press="onReportUser"/>
                    </HBox>
                </VBox>

            </VBox>
        </content>

        <endButton>
            <Button text="{i18n>close}" press="onCloseProfile"/>
        </endButton>

    </Dialog>

</core:FragmentDefinition>
