<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog id="profileDialog" title="{i18n>helperProfile}" verticalScrolling="true" stretch="{device>/system/phone}">
        <VBox class="sapUiMediumMargin">
            <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                <Avatar src="{appData>/selectedProfile/photo}" initials="{appData>/selectedProfile/initials}" displaySize="L" class="sapUiTinyMarginEnd"/>
                <VBox>
                    <Title text="{appData>/selectedProfile/name}" level="H2"/>
                    <Text text="{appData>/selectedProfile/address}" class="grayText smallText"/>
                    <Text text="{appData>/selectedProfile/serviceType}" class="smallText"/>
                    <ObjectStatus
                        text="{= ${appData>/selectedProfile/trust_level} === 'trusted_user' ? 'Trusted User' : ${appData>/selectedProfile/trust_level} === 'verified_user' ? 'Verified User' : 'New User' }"
                        state="{= ${appData>/selectedProfile/trust_level} === 'trusted_user' ? 'Success' : ${appData>/selectedProfile/trust_level} === 'verified_user' ? 'Information' : 'None' }"
                        visible="{= !!${appData>/selectedProfile/trust_level} }"/>
                </VBox>
            </HBox>

            <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                <RatingIndicator value="{appData>/selectedProfile/rating}" maxValue="5" visualMode="Half" displayOnly="true" class="sapUiTinyMarginEnd"/>
                <Text text="{= ${appData>/selectedProfile/rating} ? ${appData>/selectedProfile/rating} + ' / 5.0 rating' : 'No rating'}" class="smallText"/>
            </HBox>

            <Title text="{i18n>aboutAndHobbies}" level="H4" class="sapUiSmallMarginBottom"/>
            <Text text="{appData>/selectedProfile/hobbies}" class="smallText sapUiTinyMarginBottom"/>

            <HBox class="sapUiTinyMarginBottom" justifyContent="Start" wrap="Wrap">
                <ObjectStatus text="{appData>/selectedProfile/years} yrs experience" state="Information" class="smallText sapUiTinyMarginEnd"/>
                <ObjectStatus text="{appData>/selectedProfile/languages}" state="None" class="smallText sapUiTinyMarginEnd"/>
                <ObjectStatus text="{appData>/selectedProfile/rate} {appData>/selectedProfile/currency}/hr" state="None" class="smallText"/>
            </HBox>

            <Title text="{i18n>reviews}" level="H4" class="sapUiSmallMarginBottom"/>
            <ScrollContainer height="220px" vertical="true" horizontal="false" class="sapUiTinyMarginBottom">
                <List id="reviewsList" items="{appData>/selectedProfile/reviews}" noDataText="{i18n>noReviewsYet}">
                    <CustomListItem>
                        <HBox alignItems="Start" class="sapUiTinyMargin">
                            <Avatar initials="{appData>reviewer_initials}" displaySize="XS"
                                class="sapUiTinyMarginEnd sapUiFlexAlignSelf-Start"/>
                            <VBox width="100%">
                                <HBox justifyContent="SpaceBetween" alignItems="Center">
                                    <Text text="{appData>reviewer_name}" class="fontBold smallText"/>
                                    <RatingIndicator value="{appData>stars}" maxValue="5" displayOnly="true" iconSize="12px"/>
                                </HBox>
                                <Text text="{appData>created_at_relative}" class="smallText grayText sapUiTinyMarginBottom"/>
                                <Text text="{appData>comment}" class="smallText grayText" wrapping="true"/>
                            </VBox>
                        </HBox>
                    </CustomListItem>
                </List>
            </ScrollContainer>

            <!-- Rate this helper -->
            <Panel headerText="{i18n>rateThisHelper}" expandable="true" expanded="false" class="sapUiSmallMarginTop">
                <VBox class="sapUiSmallMargin">
                    <Label text="{i18n>yourRating}" required="true"/>
                    <RatingIndicator id="newRatingStars" maxValue="5" value="0" class="sapUiTinyMarginBottom"/>
                    <Label text="{i18n>yourComment}"/>
                    <TextArea id="newRatingComment" rows="3" width="100%" placeholder="{i18n>ratingPlaceholder}" class="sapUiTinyMarginBottom"/>
                    <Button text="{i18n>submitRating}" type="Emphasized" press="onSubmitRating" class="sapUiTinyMarginTop"/>
                </VBox>
            </Panel>

            <!-- Actions -->
            <HBox justifyContent="Center" wrap="Wrap" class="sapUiMediumMarginTop sapUiMediumMarginBottom">
                <Button text="{i18n>bookHelper}" type="Emphasized" press="onOpenBooking" class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                    visible="{= ${appData>/selectedProfile/id} !== ${appData>/user/id}}"/>
                <Button text="{i18n>messageHelper}" type="Accept" press="onStartDm" class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                    visible="{= ${appData>/selectedProfile/id} !== ${appData>/user/id}}"/>
                <Button text="Block" type="Reject" press="onBlockUser" class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                    visible="{= ${appData>/selectedProfile/id} !== ${appData>/user/id}}"/>
                <Button text="Report" type="Ghost" press="onReportUser" class="sapUiTinyMarginBottom"
                    visible="{= ${appData>/selectedProfile/id} !== ${appData>/user/id}}"/>
            </HBox>
        </VBox>
        <endButton>
            <Button text="{i18n>close}" press="onCloseProfile"/>
        </endButton>
    </Dialog>

</core:FragmentDefinition>
