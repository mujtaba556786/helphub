<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog id="notificationsDialogV2"
        title="{i18n>notifications}"
        stretch="{device>/system/phone}"
        contentWidth="400px"
        class="hhNotifDialog">

        <!-- ── Header row: count + Mark all read ── -->
        <customHeader>
            <Bar>
                <contentLeft>
                    <Title text="{i18n>notifications}"/>
                </contentLeft>
                <contentRight>
                    <Button text="Mark all read" type="Transparent" press="onMarkAllRead" visible="{= ${appData>/unreadCount} > 0}"/>
                    <Button icon="sap-icon://decline" type="Transparent" press="onCloseNotifications"/>
                </contentRight>
            </Bar>
        </customHeader>

        <VBox class="hhNotifWrap">

            <!-- ── Time-group filters ── -->
            <HBox class="hhNotifFilterRow" alignItems="Center">
                <Button text="All"       type="{= ${appData>/notifFilter} === 'all'       ? 'Emphasized' : 'Default'}" press="onNotifFilter" class="hhNotifChip">
                    <customData><core:CustomData key="filter" value="all"/></customData>
                </Button>
                <Button text="Today"     type="{= ${appData>/notifFilter} === 'today'     ? 'Emphasized' : 'Default'}" press="onNotifFilter" class="hhNotifChip">
                    <customData><core:CustomData key="filter" value="today"/></customData>
                </Button>
                <Button text="Yesterday" type="{= ${appData>/notifFilter} === 'yesterday' ? 'Emphasized' : 'Default'}" press="onNotifFilter" class="hhNotifChip">
                    <customData><core:CustomData key="filter" value="yesterday"/></customData>
                </Button>
                <Button text="Earlier"   type="{= ${appData>/notifFilter} === 'earlier'   ? 'Emphasized' : 'Default'}" press="onNotifFilter" class="hhNotifChip">
                    <customData><core:CustomData key="filter" value="earlier"/></customData>
                </Button>
            </HBox>

            <!-- ── Notification list ── -->
            <List id="notificationsList"
                items="{appData>/filteredNotifications}"
                noDataText="{i18n>noNotificationsYet}"
                showSeparators="None"
                class="hhNotifList">

                <CustomListItem type="Active" press="onNotifPress" class="hhNotifItem">
                    <HBox alignItems="Start" class="hhNotifRow">

                        <!-- Icon bubble -->
                        <VBox class="hhNotifIconWrap" justifyContent="Center" alignItems="Center">
                            <core:Icon
                                src="{path:'appData>type', formatter:'.formatNotifIconSrc'}"
                                color="{path:'appData>type', formatter:'.formatNotifIconColor'}"
                                size="1.1rem"/>
                        </VBox>

                        <!-- Content -->
                        <VBox class="hhNotifContent">
                            <HBox justifyContent="SpaceBetween" alignItems="Start">
                                <Text text="{appData>title}" class="hhNotifTitle"/>
                                <core:HTML content="{= ${appData>is_read} ? '' : '&lt;span class=&quot;hhNotifUnreadDot&quot;&gt;&lt;/span&gt;'}"/>
                            </HBox>
                            <Text text="{appData>message}" class="hhNotifMsg"/>
                            <Text text="{path:'appData>created_at', formatter:'.formatNotifTime'}" class="hhNotifTime"/>
                        </VBox>

                        <!-- Mark read button (unread only) -->
                        <Button
                            icon="sap-icon://accept"
                            type="Transparent"
                            tooltip="Mark as read"
                            visible="{= !${appData>is_read}}"
                            press="onNotifMarkOneRead"
                            class="hhNotifReadBtn"/>

                    </HBox>
                </CustomListItem>
            </List>

        </VBox>

    </Dialog>

</core:FragmentDefinition>
