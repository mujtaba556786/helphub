<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="logoutDialog"
        title="You've been signed out"
        contentWidth="320px"
        resizable="false"
        draggable="false">

        <content>
            <VBox class="sapUiMediumMargin" width="100%">

                <!-- Default state: prompt to request a new login link -->
                <VBox visible="{= !${logoutData>/linkSent} }">
                    <Text
                        text="To sign in again, we'll send a secure link to your email."
                        class="sapUiSmallMarginBottom" />
                    <Text
                        text="{logoutData>/email}"
                        class="sapUiSmallMarginBottom"
                        wrapping="true" />
                </VBox>

                <!-- After link is sent -->
                <VBox visible="{= !!${logoutData>/linkSent} }">
                    <Title text="📧 Check your inbox" level="H4" class="sapUiSmallMarginBottom" />
                    <Text
                        text="A sign-in link has been sent to {logoutData>/email}. Tap the link in the email to sign back in."
                        wrapping="true" />
                </VBox>

            </VBox>
        </content>

        <buttons>
            <!-- Send link button — hidden once link is sent -->
            <Button
                text="Send Login Link"
                type="Emphasized"
                press=".onLogoutSendLink"
                visible="{= !${logoutData>/linkSent} }" />

            <!-- Close / back to login -->
            <Button
                text="Back to Login"
                press=".onLogoutClose" />
        </buttons>

    </Dialog>

</core:FragmentDefinition>
