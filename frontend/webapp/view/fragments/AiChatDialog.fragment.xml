<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog id="chatDialog" title="{i18n>aiChat}"
        contentHeight="65vh" contentWidth="92%"
        verticalScrolling="false"
        stretch="{device>/system/phone}">

        <!-- Quick replies pinned below header -->
        <subHeader>
            <Bar>
                <contentLeft>
                    <HBox wrap="Wrap" alignItems="Center" class="sapUiTinyMarginBeginEnd sapUiTinyMarginTopBottom">
                        <Button icon="sap-icon://car-rental"    text="{i18n>qrOnMyWay}"     type="Transparent" press="onQuickReply" class="hhQRChip sapUiTinyMarginEnd"/>
                        <Button icon="sap-icon://accept"        text="{i18n>qrImAvailable}" type="Transparent" press="onQuickReply" class="hhQRChip sapUiTinyMarginEnd"/>
                        <Button icon="sap-icon://appointment-2" text="{i18n>qrReschedule}"  type="Transparent" press="onQuickReply" class="hhQRChip sapUiTinyMarginEnd"/>
                        <Button icon="sap-icon://goodbye"       text="{i18n>qrSeeSoon}"     type="Transparent" press="onQuickReply" class="hhQRChip sapUiTinyMarginEnd"/>
                        <Button icon="sap-icon://sys-enter-2"   text="{i18n>qrAllDone}"     type="Transparent" press="onQuickReply" class="hhQRChip sapUiTinyMarginEnd"/>
                    </HBox>
                </contentLeft>
            </Bar>
        </subHeader>

        <!-- Messages area fills remaining space -->
        <content>
            <ScrollContainer id="chatScrollContainer" height="100%" vertical="true" horizontal="false">
                <core:HTML id="chatMessagesHtml" content="&lt;div&gt;&lt;/div&gt;"/>
                <HBox id="chatTypingIndicator" visible="false" alignItems="Center" class="sapUiTinyMarginBegin sapUiTinyMarginBottom">
                    <BusyIndicator size="1rem" class="sapUiTinyMarginEnd"/>
                    <Text text="{i18n>typing}" class="grayText smallText"/>
                </HBox>
            </ScrollContainer>
        </content>

        <!-- Input + Close pinned to bottom -->
        <footer>
            <Bar>
                <contentLeft>
                    <Input id="chatInput" placeholder="{i18n>askAnything}" submit="onChatSend"/>
                </contentLeft>
                <contentRight>
                    <Button id="chatSendBtn" icon="sap-icon://paper-plane" type="Emphasized" press="onChatSend"/>
                    <Button text="{i18n>close}" press="onCloseChat"/>
                </contentRight>
            </Bar>
        </footer>

    </Dialog>

</core:FragmentDefinition>
