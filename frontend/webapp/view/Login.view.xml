<mvc:View
    controllerName="helphub.controller.Login"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    displayBlock="true">

    <Page showHeader="false">
        <FlexBox height="100vh" alignItems="Center" justifyContent="Center" direction="Column" class="loginBg">
            <VBox width="90%" class="loginCard maxWidth400">
                <VBox alignItems="Center" class="sapUiMediumMargin">
                    <Avatar displaySize="XL" backgroundColor="Accent6" initials="❤️" class="sapUiSmallMarginBottom"/>
                    <Title text="{i18n>loginTitle}" level="H1" class="sapUiTinyMarginBottom"/>
                    <Text text="{i18n>loginNeighborhoodNetwork}" class="grayText"/>
                    <Text text="{i18n>loginTagline}" class="grayText textCenter"/>
                    <HBox class="sapUiTinyMarginTop" justifyContent="Center">
                    </HBox>
                </VBox>

                <!-- Step 1: Enter Email -->
                <VBox id="stepEmail" class="sapUiMediumMargin">
                    <Label text="{i18n>loginEmailLabel}"/>
                    <Input id="emailInput" type="Email" placeholder="{i18n>loginEmailPlaceholder}" class="sapUiSmallMarginBottom"/>
                    <Button text="{i18n>loginSendLink}" type="Emphasized" width="100%" press="onSendMagicLink"/>
                    <!-- Demo login -->
                    <Button text="{i18n>loginDemoLogin}" icon="sap-icon://person-placeholder" width="100%" type="Ghost" class="sapUiSmallMarginTop" press="onDemoLogin"/>
                </VBox>

                <!-- Step 2: Link sent confirmation -->
                <VBox id="stepLinkSent" class="sapUiMediumMargin" visible="false">
                    <VBox alignItems="Center" class="sapUiSmallMarginBottom">
                        <Title text="{i18n>loginCheckInbox}" level="H3"/>
                        <Text id="linkSentHint" text="" class="grayText textCenter sapUiTinyMarginTop sapUiSmallMarginBottom"/>
                        <Text text="{i18n>loginClickLink}" class="grayText textCenter"/>
                    </VBox>
                    <Button text="{i18n>loginResendLink}" type="Transparent" width="100%" class="sapUiSmallMarginTop" press="onResendMagicLink"/>
                    <Button text="{i18n>loginDifferentEmail}" type="Ghost" width="100%" class="sapUiTinyMarginTop" press="onBackToEmail"/>
                </VBox>
            </VBox>
        </FlexBox>
    </Page>
</mvc:View>
