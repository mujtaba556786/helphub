<mvc:View
    controllerName="helphub.controller.Login"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    displayBlock="true">

    <Page showHeader="false">
        <FlexBox height="100vh" alignItems="Center" justifyContent="Center" direction="Column" class="loginBg">
            <VBox width="90%" class="loginCard maxWidth400">
                <VBox alignItems="Center" class="sapUiMediumMargin">
                    <Avatar displaySize="XL" backgroundColor="Accent6" initials="❤️" class="sapUiSmallMarginBottom"/>
                    <Title text="HelpMate" level="H1" class="sapUiTinyMarginBottom"/>
                    <Text text="Neighborhood Help Network" class="grayText"/>
                    <Text text="Get everyday tasks done by trusted neighbors." class="grayText textCenter"/>
                    <HBox class="sapUiTinyMarginTop" justifyContent="Center">
                    </HBox>
                </VBox>

                <!-- Step 1: Enter Email -->
                <VBox id="stepEmail" class="sapUiMediumMargin">
                    <Label text="Email Address"/>
                    <Input id="emailInput" type="Email" placeholder="you@example.com" class="sapUiSmallMarginBottom"/>
                    <Button text="Send Sign-in Link" type="Emphasized" width="100%" press="onSendMagicLink"/>
                    <!-- Demo login -->
                    <Button text="Demo Login" icon="sap-icon://person-placeholder" width="100%" type="Ghost" class="sapUiSmallMarginTop" press="onDemoLogin"/>
                </VBox>

                <!-- Step 2: Link sent confirmation -->
                <VBox id="stepLinkSent" class="sapUiMediumMargin" visible="false">
                    <VBox alignItems="Center" class="sapUiSmallMarginBottom">
                        <Title text="Check your inbox" level="H3"/>
                        <Text id="linkSentHint" text="" class="grayText textCenter sapUiTinyMarginTop sapUiSmallMarginBottom"/>
                        <Text text="Click the link in the email to sign in — no code needed." class="grayText textCenter"/>
                    </VBox>
                    <Button text="Resend link" type="Transparent" width="100%" class="sapUiSmallMarginTop" press="onResendMagicLink"/>
                    <Button text="← Use a different email" type="Ghost" width="100%" class="sapUiTinyMarginTop" press="onBackToEmail"/>
                </VBox>
            </VBox>
        </FlexBox>
    </Page>
</mvc:View>
