<mvc:View controllerName="helphub.controller.Dashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns:u="sap.ui.unified"
    xmlns:l="sap.ui.layout"
    xmlns:data="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
    displayBlock="true">

    <NavContainer id="navContainer">

        <!-- PAGE 1: CATEGORY SELECTION -->
        <Page id="dashboardPage" title="HelpMate" showHeader="true"  enableScrolling="true">
            <customHeader>
                <Bar>
                    <contentLeft>
                        <HBox alignItems="Center">
                            <Title text="HelpMate" level="H3" class="sapUiTinyMarginBegin"/>
                        </HBox>
                    </contentLeft>
                    <contentRight>
                        <HBox alignItems="Center" class="sapUiTinyMarginEnd">
                            <Button id="notifBtn" icon="sap-icon://bell" type="Transparent" press="onShowNotifications" tooltip="Notifications"/>
                            <Avatar src="{appData>/user/photo}" initials="{appData>/user/initials}" displaySize="XS" backgroundColor="Accent6" press="onEditProfile" class="sapUiTinyMarginEnd" />
                            <Button icon="sap-icon://log" press="onLogout" type="Transparent" tooltip="Sign out"/>
                        </HBox>
                    </contentRight>
                </Bar>
            </customHeader>

            <content>
                <IconTabBar expandable="false" select=".onTabSelect">

                    <!-- TAB 1: Find Help -->
                    <items>
                        <IconTabFilter key="findHelp" text="Find Help" icon="sap-icon://question-mark">
                            <ScrollContainer vertical="true" horizontal="false" height="100%">
                                <VBox class="sapUiSmallMargin mainContent">
                                    <Title text="How can we help you today?" level="H2" class="sapUiLargeMarginBottom"/>
                                    <Text text="Choose a service below to find trusted helpers near you." class="grayText sapUiSmallMarginBottom"/>

                                    <!-- Service tiles -->
                                    <FlexBox class="serviceTilesContainer" direction="Row" wrap="Wrap" justifyContent="Center" items="{appData>/services}">
                                        <items>
                                            <CustomListItem class="hhTileItem" type="Active" press=".onServicePress">
                                                <HBox direction="Column">
                                                    <VBox class="circleButton" core:style="background-color:{appData>color}">
                                                        <Text text="{appData>icon}" class="serviceIcon"/>
                                                    </VBox>
                                                    <Text text="{appData>name}" class="serviceName"/>
                                                </HBox>
                                            </CustomListItem>
                                        </items>
                                    </FlexBox>

                                </VBox>
                            </ScrollContainer>
                        </IconTabFilter>

                        <!-- TAB 2: My Schedule -->
                        <IconTabFilter key="mySchedule" text="My Schedule" icon="sap-icon://calendar" count="{appData>/bookingCount}">
                            <ScrollContainer vertical="true" horizontal="false" height="100%">
                                <VBox class="sapUiSmallMargin">
                                    <Title text="Your Bookings" level="H4" class="sapUiSmallMarginBottom"/>
                                    <List id="bookingsList" items="{appData>/upcomingBookings}" noDataText="No bookings yet. Book a helper to get started!">
                                        <CustomListItem>
                                            <VBox class="sapUiSmallMargin">
                                                <HBox justifyContent="SpaceBetween" alignItems="Start" wrap="Wrap">
                                                    <VBox class="bookingInfoBox">
                                                        <Title text="{appData>service}" level="H5"/>
                                                        <Text text="{appData>provider_name}" class="grayText smallText"/>
                                                        <Text text="{appData>scheduled_date} {appData>scheduled_time}" class="smallText blueText"/>
                                                    </VBox>
                                                    <VBox alignItems="End" class="bookingActionsBox">
                                                        <ObjectStatus text="{appData>status}" state="{path:'appData>status', formatter:'.formatBookingState'}"/>
                                                        <HBox class="sapUiTinyMarginTop" wrap="Wrap" visible="{= ${appData>status} === 'pending' &amp;&amp; ${appData>/user/id} === ${appData>provider_id}}">
                                                            <Button text="✓ Accept" type="Accept" press="onAcceptBooking" class="sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
                                                            <Button text="✗ Decline" type="Reject" press="onDeclineBooking" class="sapUiTinyMarginBottom"/>
                                                        </HBox>
                                                    </VBox>
                                                </HBox>
                                                <Text text="{appData>message}" class="smallText grayText sapUiTinyMarginTop" visible="{= !!${appData>message}}"/>
                                            </VBox>
                                        </CustomListItem>
                                    </List>
                                </VBox>
                            </ScrollContainer>
                        </IconTabFilter>
                        <!-- TAB 3: Saved -->
                        <IconTabFilter key="saved" text="Saved" icon="sap-icon://heart">
                            <ScrollContainer vertical="true" horizontal="false" height="100%">
                                <VBox class="sapUiSmallMargin mainContent">

                                    <!-- Recently Viewed -->
                                    <Title text="Recently Viewed" level="H4" class="sapUiSmallMarginBottom"/>
                                    <List id="recentlyViewedList" items="{appData>/recentlyViewed}" noDataText="No helpers viewed yet.">
                                        <CustomListItem>
                                            <HBox class="sapUiSmallMargin" justifyContent="SpaceBetween" alignItems="Center">
                                                <HBox alignItems="Center">
                                                    <Avatar displaySize="S" src="{appData>photo}" initials="P" backgroundColor="Accent1" class="sapUiTinyMarginEnd"/>
                                                    <VBox>
                                                        <Title text="{appData>name}" level="H5"/>
                                                        <Text text="{appData>serviceType}" class="grayText smallText"/>
                                                    </VBox>
                                                </HBox>
                                                <Button text="Profile" type="Transparent" press="onViewRecentProfile"/>
                                            </HBox>
                                        </CustomListItem>
                                    </List>

                                    <!-- Saved Helpers -->
                                    <Title text="Saved Helpers" level="H4" class="sapUiSmallMarginTop sapUiSmallMarginBottom"/>
                                    <List id="favoritesList" items="{appData>/favoriteProviders}" noDataText="No saved helpers yet. Tap ♡ on a helper card to save them.">
                                        <CustomListItem>
                                            <HBox class="sapUiSmallMargin" justifyContent="SpaceBetween" alignItems="Center">
                                                <HBox alignItems="Center">
                                                    <Avatar displaySize="S" src="{appData>photo}" initials="P" backgroundColor="Accent1" class="sapUiTinyMarginEnd"/>
                                                    <VBox>
                                                        <Title text="{appData>name}" level="H5"/>
                                                        <Text text="{appData>serviceType}" class="grayText smallText"/>
                                                        <HBox alignItems="Center">
                                                            <RatingIndicator value="{appData>rating}" displayOnly="true" iconSize="12px" class="sapUiTinyMarginEnd"/>
                                                            <Text text="{path:'appData>', formatter:'.formatPriceDisplay'}" class="smallText blueText"/>
                                                        </HBox>
                                                    </VBox>
                                                </HBox>
                                                <VBox alignItems="End">
                                                    <Button icon="sap-icon://favorite" type="Emphasized" press="onToggleFavorite" tooltip="Remove from saved" class="sapUiTinyMarginBottom"/>
                                                    <Button text="Profile" type="Transparent" press="onViewFavoriteProfile"/>
                                                </VBox>
                                            </HBox>
                                        </CustomListItem>
                                    </List>

                                </VBox>
                            </ScrollContainer>
                        </IconTabFilter>

                    </items>

                </IconTabBar>
            </content>
        </Page>

        <!-- PAGE 2: Search & Results -->
        <Page id="searchPage" title="Local Experts" showNavButton="true" navButtonPress="onNavBack" enableScrolling="true">
            <content>
                <VBox>
                    <VBox id="mapContainer" height="35vh" width="100%" class="mapPlaceholder">
                        <core:HTML content='&lt;div id="googleMap" class="mapDiv"&gt;Map View Centered on You&lt;/div&gt;'/>
                    </VBox>

                    <VBox class="sapUiSmallMargin flexBasis65">
                        <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMarginBottom">
                            <Title text="{appData>/selectedCategoryName} Experts Nearby" level="H3"/>
                        </HBox>

                        <SearchField id="helperSearch" placeholder="Search by name or skill…" search="onHelperSearch" liveChange="onHelperSearch" width="100%" class="sapUiTinyMarginBottom"/>

                        <VBox class="sapUiTinyMarginBottom">
                            <HBox justifyContent="SpaceBetween" alignItems="Center">
                                <Text text="Search radius (km)" class="smallText grayText"/>
                                <Text text="{appData>/filters/distanceLabel}" class="smallText blueText"/>
                            </HBox>
                            <Slider min="1" max="50" step="1" value="{appData>/filters/distance}" liveChange="onDistanceChange"/>
                        </VBox>

                        <HBox class="sapUiTinyMarginBottom" justifyContent="SpaceBetween" alignItems="Center">
                            <HBox>
                                <Button text="All" type="Transparent" press="onFilterAll"/>
                                <Button text="Top rated" type="Transparent" press="onFilterTopRated"/>
                                <Button text="Budget" type="Transparent" press="onFilterBudget"/>
                            </HBox>
                            <Button icon="sap-icon://filter" text="Filters" type="Transparent" press="onOpenFilters"/>
                        </HBox>

                        <!-- Ad slot: banner between filters and helper list (non-intrusive) -->
                        <core:HTML content='&lt;div id="ad-slot-top" style="text-align:center;margin:4px 0;min-height:50px;background:#f5f5f5;border:1px dashed #ccc;display:flex;align-items:center;justify-content:center;"&gt;&lt;ins class="adsbygoogle" style="display:inline-block;width:100%;height:50px;" data-ad-client="ca-pub-XXXXXXXXXXXXXXXX" data-ad-slot="1111111111"&gt;&lt;/ins&gt;&lt;span style="color:#aaa;font-size:11px;font-family:sans-serif;position:absolute;"&gt;Advertisement&lt;/span&gt;&lt;/div&gt;'/>

                        <List items="{appData>/filteredProviders}" noDataText="No helpers nearby yet. Showing more helpers as they join.">
                            <CustomListItem>
                                <HBox class="sapUiSmallMargin" justifyContent="SpaceBetween" alignItems="Center">
                                    <VBox>
                                        <HBox alignItems="Center">
                                            <Avatar displaySize="S" src="{appData>photo}" initials="P" backgroundColor="Accent1" class="sapUiTinyMarginEnd"/>
                                            <VBox>
                                                <Title text="{appData>name}" level="H4"/>
                                                <Text text="{appData>address}" class="grayText smallText"/>
                                            </VBox>
                                        </HBox>
                                        <HBox class="sapUiTinyMarginTop" alignItems="Center">
                                            <RatingIndicator value="{appData>rating}" displayOnly="true" iconSize="14px" class="sapUiTinyMarginEnd"/>
                                            <Text text="{path:'appData>', formatter:'.formatDistance'}" class="blueText fontBold smallText"/>
                                        </HBox>
                                        <HBox class="sapUiTinyMarginTop" wrap="Wrap">
                                            <ObjectStatus text="{appData>years} yrs experience" state="Information" class="smallText sapUiTinyMarginEnd"/>
                                            <ObjectStatus text="{appData>languages}" state="None" class="smallText"/>
                                        </HBox>
                                    </VBox>
                                    <VBox alignItems="End" wrap="NoWrap" class="helperCardActions">
                                        <ObjectStatus text="{path:'appData>', formatter:'.formatAvailabilityStatus'}" state="{path:'appData>', formatter:'.formatAvailabilityState'}" class="fontBold"/>
                                        <Title text="{path:'appData>', formatter:'.formatPriceDisplay'}" level="H4" class="sapUiTinyMarginTop"/>
                                        <Button icon="{= ${appData>/favorites}.indexOf(${appData>id}) >= 0 ? 'sap-icon://favorite' : 'sap-icon://unfavorite'}" type="{= ${appData>/favorites}.indexOf(${appData>id}) >= 0 ? 'Emphasized' : 'Transparent'}" press="onToggleFavorite" class="sapUiTinyMarginTop helperCardBtn" tooltip="Save helper"/>
                                        <Button text="Profile" type="Transparent" class="sapUiTinyMarginTop helperCardBtn" press="onViewProfile"/>
                                        <Button text="📅 Book" type="Emphasized" class="sapUiTinyMarginTop helperCardBtn" press="onQuickBook"/>
                                        <Button text="💬 Chat" type="Accept" class="sapUiTinyMarginTop helperCardBtn" press="onQuickChat"/>
                                    </VBox>
                                </HBox>
                            </CustomListItem>
                        </List>

                        <!-- Ad slot: banner below helper list -->
                        <core:HTML content='&lt;div id="ad-slot-bottom" style="text-align:center;margin:8px 0;min-height:50px;background:#f5f5f5;border:1px dashed #ccc;display:flex;align-items:center;justify-content:center;"&gt;&lt;ins class="adsbygoogle" style="display:inline-block;width:100%;height:50px;" data-ad-client="ca-pub-XXXXXXXXXXXXXXXX" data-ad-slot="2222222222"&gt;&lt;/ins&gt;&lt;span style="color:#aaa;font-size:11px;font-family:sans-serif;position:absolute;"&gt;Advertisement&lt;/span&gt;&lt;/div&gt;'/>

                    </VBox>
                </VBox>
            </content>
        </Page>

        <!-- PAGE 3: Edit Profile -->
        <Page id="editPage" title="My Profile" showNavButton="true" navButtonPress="onNavBack" enableScrolling="true">
            <content>
                <VBox class="sapUiSmallMargin">

                    <!-- PROFILE PHOTO -->
                    <VBox alignItems="Center" class="sapUiMediumMarginBottom">
                        <Avatar id="profileAvatar" src="{appData>/user/photo}" displaySize="XL" backgroundColor="Accent6" initials="{appData>/user/avatar}" class="sapUiSmallMarginBottom"/>
                        <Button text="Change Photo" icon="sap-icon://camera" press="onChangePhoto" type="Transparent"/>
                        <u:FileUploader id="avatarFileUploader" fileType="jpg,jpeg,png,gif,webp" maximumFileSize="5" visible="false" change="onAvatarFileSelected" uploadOnChange="false" buttonOnly="true" buttonText=""/>
                        <Text id="photoError" text="" class="errorText" visible="false"/>
                    </VBox>

                    <f:SimpleForm editable="true" layout="ResponsiveGridLayout" columnsL="2" columnsM="2">

                        <!-- Basic Info -->
                        <core:Title text="Basic Information"/>

                        <Label text="Display Name" required="true"/>
                        <Input value="{appData>/user/name}" valueState="{appData>/validation/name}" valueStateText="Display name is required"/>

                        <Label text="Phone Number"/>
                        <Input value="{appData>/user/phone}" type="Tel"/>

                        <Label text="Languages"/>
                        <Input value="{appData>/user/languages}" placeholder="e.g. EN, DE"/>

                        <Label text="Bio"/>
                        <TextArea rows="3" value="{appData>/user/bio}" placeholder="Tell clients about your experience…"/>

                        <!-- Provider Info -->
                        <core:Title text="Provider Settings"/>

                        <Label text="Service Categories"/>
                        <MultiComboBox selectedKeys="{appData>/user/serviceCategories}" items="{appData>/services}">
                            <core:Item key="{appData>name}" text="{appData>name}"/>
                        </MultiComboBox>

                        <Label text="Hourly Rate (EUR)"/>
                        <Input value="{appData>/user/rate}" type="Number"/>

                        <Label text="Availability"/>
                        <!-- Quick picks row -->
                        <FlexBox wrap="Wrap" class="sapUiTinyMarginBottom">
                            <Button text="All Day" press="onAvailabilityToggle" type="{= ${appData>/user/availabilityFlags/all_day} ? 'Emphasized' : 'Default'}" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
                                <customData>
                                    <core:CustomData key="availKey" value="all_day"/>
                                </customData>
                            </Button>
                            <Button text="Weekdays" press="onAvailabilityToggle" type="{= ${appData>/user/availabilityFlags/weekdays} ? 'Emphasized' : 'Default'}" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
                                <customData>
                                    <core:CustomData key="availKey" value="weekdays"/>
                                </customData>
                            </Button>
                            <Button text="Weekends" press="onAvailabilityToggle" type="{= ${appData>/user/availabilityFlags/weekends} ? 'Emphasized' : 'Default'}" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
                                <customData>
                                    <core:CustomData key="availKey" value="weekends"/>
                                </customData>
                            </Button>
                        </FlexBox>
                        <!-- Time of day row -->
                        <FlexBox wrap="Wrap">
                            <Button text="🌅 Morning (6–12)" press="onAvailabilityToggle" type="{= ${appData>/user/availabilityFlags/morning} ? 'Emphasized' : 'Default'}" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
                                <customData>
                                    <core:CustomData key="availKey" value="morning"/>
                                </customData>
                            </Button>
                            <Button text="☀️ Afternoon (12–17)" press="onAvailabilityToggle" type="{= ${appData>/user/availabilityFlags/afternoon} ? 'Emphasized' : 'Default'}" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
                                <customData>
                                    <core:CustomData key="availKey" value="afternoon"/>
                                </customData>
                            </Button>
                            <Button text="🌆 Evening (17–22)" press="onAvailabilityToggle" type="{= ${appData>/user/availabilityFlags/evening} ? 'Emphasized' : 'Default'}" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
                                <customData>
                                    <core:CustomData key="availKey" value="evening"/>
                                </customData>
                            </Button>
                            <Button text="🌙 Night (22+)" press="onAvailabilityToggle" type="{= ${appData>/user/availabilityFlags/night} ? 'Emphasized' : 'Default'}" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
                                <customData>
                                    <core:CustomData key="availKey" value="night"/>
                                </customData>
                            </Button>
                        </FlexBox>

                        <Label text="Years of Experience"/>
                        <Input value="{appData>/user/years}" type="Number"/>

                        <!-- Address -->
                        <core:Title text="Address"/>

                        <Label text="Country" required="true"/>
                        <Select id="countrySelect" change="onCountryChange" selectedKey="{appData>/user/address/country}" items="{appData>/countries}">
                            <core:Item key="{appData>code}" text="{appData>name}"/>
                        </Select>

                        <Label text="State / Province" required="true"/>
                        <Select id="stateSelect" selectedKey="{appData>/user/address/state}" items="{appData>/stateOptions}">
                            <core:Item key="{appData>name}" text="{appData>name}"/>
                        </Select>

                        <Label text="City" required="true"/>
                        <Input id="cityInput" value="{appData>/user/address/city}" valueState="{appData>/validation/city}" valueStateText="City is required"/>

                        <Label text="Street" required="true"/>
                        <Input id="streetInput" value="{appData>/user/address/street}" valueState="{appData>/validation/street}" valueStateText="Street is required"/>

                        <Label text="House Number" required="true"/>
                        <Input id="houseInput" value="{appData>/user/address/houseNumber}" valueState="{appData>/validation/houseNumber}" valueStateText="House number is required"/>

                        <Label text="Postal Code" required="true"/>
                        <Input id="postalInput" value="{appData>/user/address/postalCode}" valueState="{appData>/validation/postalCode}" valueStateText="Enter a valid postal code (3–10 characters)"/>

                    </f:SimpleForm>

                    <Button text="Save Profile Changes" type="Emphasized" press="onSaveProfile" class="sapUiMediumMarginTop sapUiLargeMarginBottom" width="100%"/>

                </VBox>

            </content>

            <dependents>

                <!-- Onboarding Dialog -->
                <Dialog id="onboardingDialog" contentWidth="92%" verticalScrolling="true">
                    <customHeader>
                        <Bar>
                            <contentLeft>
                                <Title text="{= ${appData>/onboarding/step} === 1 ? '👋 Welcome to HelpHub' : ${appData>/onboarding/step} === 2 ? '⚙️ How it works' : '🎯 Pick your interests'}" level="H4"/>
                            </contentLeft>
                            <contentRight>
                                <Text text="{= ${appData>/onboarding/step} + ' / 3'}" class="grayText smallText sapUiTinyMarginEnd"/>
                            </contentRight>
                        </Bar>
                    </customHeader>
                    <!-- Step 1: Welcome -->
                    <VBox visible="{= ${appData>/onboarding/step} === 1}" class="sapUiMediumMargin hhOnboardStep">
                        <core:HTML content="&lt;div style='text-align:center;font-size:64px;margin-bottom:12px'&gt;🏠&lt;/div&gt;"/>
                        <Title text="Find trusted helpers near you" level="H2" class="sapUiSmallMarginBottom textCenter"/>
                        <Text text="HelpHub connects you with verified local helpers for everyday tasks — gardening, babysitting, IT support and more." class="grayText sapUiSmallMarginBottom textCenter"/>
                        <VBox class="sapUiSmallMarginTop">
                            <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                                <core:HTML content="&lt;span style='font-size:20px;margin-right:8px'&gt;📍&lt;/span&gt;"/>
                                <Text text="Find helpers near your location"/>
                            </HBox>
                            <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                                <core:HTML content="&lt;span style='font-size:20px;margin-right:8px'&gt;💬&lt;/span&gt;"/>
                                <Text text="Chat and book in seconds"/>
                            </HBox>
                        </VBox>
                    </VBox>
                    <!-- Step 2: How it works -->
                    <VBox visible="{= ${appData>/onboarding/step} === 2}" class="sapUiMediumMargin hhOnboardStep">
                        <VBox class="hhOnboardCard sapUiSmallMarginBottom">
                            <HBox alignItems="Center">
                                <core:HTML content="&lt;div class='hhOnboardNum'&gt;1&lt;/div&gt;"/>
                                <VBox class="sapUiTinyMarginBegin">
                                    <Title text="Choose a service" level="H5"/>
                                    <Text text="Pick from 12 categories like gardening, cleaning, IT support and more." class="grayText smallText"/>
                                </VBox>
                            </HBox>
                        </VBox>
                        <VBox class="hhOnboardCard sapUiSmallMarginBottom">
                            <HBox alignItems="Center">
                                <core:HTML content="&lt;div class='hhOnboardNum'&gt;2&lt;/div&gt;"/>
                                <VBox class="sapUiTinyMarginBegin">
                                    <Title text="Browse &amp; compare helpers" level="H5"/>
                                    <Text text="See ratings, experience, price, distance and availability at a glance." class="grayText smallText"/>
                                </VBox>
                            </HBox>
                        </VBox>
                        <VBox class="hhOnboardCard sapUiSmallMarginBottom">
                            <HBox alignItems="Center">
                                <core:HTML content="&lt;div class='hhOnboardNum'&gt;3&lt;/div&gt;"/>
                                <VBox class="sapUiTinyMarginBegin">
                                    <Title text="Book &amp; relax" level="H5"/>
                                    <Text text="Send a booking request, chat with the helper and track your schedule." class="grayText smallText"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </VBox>
                    <!-- Step 3: Pick interests -->
                    <VBox visible="{= ${appData>/onboarding/step} === 3}" class="sapUiMediumMargin hhOnboardStep">
                        <Text text="Select services you're most interested in." class="grayText sapUiSmallMarginBottom"/>
                        <FlexBox wrap="Wrap" class="sapUiTinyMarginTop">
                            <Button text="🌱 Gardening"    data:interestKey="Gardening"    press="onToggleInterest" class="hhInterestBtn sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
                            <Button text="👶 Babysitting"  data:interestKey="Babysitting"  press="onToggleInterest" class="hhInterestBtn sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
                            <Button text="🚗 Transport"    data:interestKey="Transport"    press="onToggleInterest" class="hhInterestBtn sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
                            <Button text="🛒 Groceries"    data:interestKey="Groceries"    press="onToggleInterest" class="hhInterestBtn sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
                            <Button text="📐 Math Tuition" data:interestKey="Math Tuition" press="onToggleInterest" class="hhInterestBtn sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
                            <Button text="🧹 Cleaning"     data:interestKey="Cleaning"     press="onToggleInterest" class="hhInterestBtn sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
                            <Button text="🐕 Pet Care"     data:interestKey="Pet Care"     press="onToggleInterest" class="hhInterestBtn sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
                            <Button text="🔧 Handyman"     data:interestKey="Handyman"     press="onToggleInterest" class="hhInterestBtn sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
                            <Button text="👨‍🍳 Cooking"    data:interestKey="Cooking"      press="onToggleInterest" class="hhInterestBtn sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
                            <Button text="📦 Moving"       data:interestKey="Moving"       press="onToggleInterest" class="hhInterestBtn sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
                            <Button text="💻 IT Support"   data:interestKey="IT Support"   press="onToggleInterest" class="hhInterestBtn sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
                        </FlexBox>
                    </VBox>
                    <beginButton>
                        <Button text="Skip" type="Transparent" press="onOnboardingSkip" visible="{= ${appData>/onboarding/step} === 1}"/>
                    </beginButton>
                    <endButton>
                        <Button text="{= ${appData>/onboarding/step} === 3 ? 'Get Started 🚀' : 'Next →'}" type="Emphasized" press="onOnboardingNext"/>
                    </endButton>
                </Dialog>

                <!-- Filter Dialog -->
                <Dialog id="filterDialog" title="Filter Helpers" contentWidth="92%">
                    <VBox class="sapUiMediumMargin">
                        <Label text="Minimum rating"/>
                        <Select id="filterRatingSelect" selectedKey="{appData>/filters/minRating}" width="100%" class="sapUiTinyMarginBottom">
                            <core:Item key="0"   text="Any rating"/>
                            <core:Item key="4.0" text="4.0+ stars"/>
                            <core:Item key="4.5" text="4.5+ stars"/>
                            <core:Item key="4.8" text="4.8+ stars (Top rated)"/>
                        </Select>
                        <Label text="Language" class="sapUiTinyMarginTop"/>
                        <Input id="filterLangInput" value="{appData>/filters/language}" placeholder="e.g. EN or DE" width="100%" class="sapUiTinyMarginBottom"/>
                        <Label text="Max hourly rate (EUR)" class="sapUiTinyMarginTop"/>
                        <HBox justifyContent="SpaceBetween" alignItems="Center">
                            <Text text="€0" class="smallText grayText"/>
                            <Text text="{= '€' + ${appData>/filters/maxPrice} + '/hr'}" class="smallText blueText fontBold"/>
                            <Text text="€200+" class="smallText grayText"/>
                        </HBox>
                        <Slider id="filterPriceSlider" min="0" max="200" step="5" value="{appData>/filters/maxPrice}" width="100%"/>
                    </VBox>
                    <beginButton>
                        <Button text="Reset" press="onResetFilters"/>
                    </beginButton>
                    <endButton>
                        <Button text="Apply" type="Emphasized" press="onApplyFilters"/>
                    </endButton>
                </Dialog>

                <!-- Profile dialog -->
                <Dialog id="profileDialog" title="Helper profile" verticalScrolling="true">
                    <VBox class="sapUiMediumMargin">
                        <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                            <Avatar src="{appData>/selectedProfile/photo}" initials="{appData>/selectedProfile/initials}" displaySize="L" class="sapUiTinyMarginEnd"/>
                            <VBox>
                                <Title text="{appData>/selectedProfile/name}" level="H2"/>
                                <Text text="{appData>/selectedProfile/address}" class="grayText smallText"/>
                                <Text text="{appData>/selectedProfile/serviceType}" class="smallText"/>
                            </VBox>
                        </HBox>

                        <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                            <RatingIndicator value="{appData>/selectedProfile/rating}" maxValue="5" visualMode="Half" displayOnly="true" class="sapUiTinyMarginEnd"/>
                            <Text text="{= ${appData>/selectedProfile/rating} ? ${appData>/selectedProfile/rating} + ' / 5.0 rating' : 'No rating'}" class="smallText"/>
                        </HBox>

                        <Title text="About &amp; hobbies" level="H4" class="sapUiSmallMarginBottom"/>
                        <Text text="{appData>/selectedProfile/hobbies}" class="smallText sapUiTinyMarginBottom"/>

                        <HBox class="sapUiTinyMarginBottom" justifyContent="Start" wrap="Wrap">
                            <ObjectStatus text="{appData>/selectedProfile/years} yrs experience" state="Information" class="smallText sapUiTinyMarginEnd"/>
                            <ObjectStatus text="{appData>/selectedProfile/languages}" state="None" class="smallText sapUiTinyMarginEnd"/>
                            <ObjectStatus text="{appData>/selectedProfile/rate} {appData>/selectedProfile/currency}/hr" state="None" class="smallText"/>
                        </HBox>

                        <Title text="Reviews" level="H4" class="sapUiSmallMarginBottom"/>
                        <List id="reviewsList" items="{appData>/selectedProfile/reviews}" noDataText="No reviews yet — be the first!">
                            <CustomListItem>
                                <VBox class="sapUiTinyMargin">
                                    <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                                        <RatingIndicator value="{appData>stars}" maxValue="5" displayOnly="true" iconSize="12px" class="sapUiTinyMarginEnd"/>
                                        <Text text="{appData>reviewer_name}" class="fontBold smallText"/>
                                    </HBox>
                                    <Text text="{appData>comment}" class="smallText grayText"/>
                                </VBox>
                            </CustomListItem>
                        </List>

                        <!-- Rate this helper -->
                        <Panel headerText="Rate this helper" expandable="true" expanded="false" class="sapUiSmallMarginTop">
                            <VBox class="sapUiSmallMargin">
                                <Label text="Your rating" required="true"/>
                                <RatingIndicator id="newRatingStars" maxValue="5" value="0" class="sapUiTinyMarginBottom"/>
                                <Label text="Your comment (optional)"/>
                                <TextArea id="newRatingComment" rows="3" width="100%" placeholder="Tell others about your experience…" class="sapUiTinyMarginBottom"/>
                                <Button text="Submit Rating" type="Emphasized" press="onSubmitRating" class="sapUiTinyMarginTop"/>
                            </VBox>
                        </Panel>

                        <!-- Actions inside content for proper layout -->
                        <HBox justifyContent="Center" wrap="Wrap" class="sapUiMediumMarginTop sapUiMediumMarginBottom">
                            <Button text="📅 Book Helper" type="Emphasized" press="onOpenBooking" class="sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
                            <Button text="💬 Chat" type="Accept" press="onOpenChat" class="sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
                        </HBox>
                    </VBox>

                    <endButton>
                        <Button text="Close" press="onCloseProfile"/>
                    </endButton>
                </Dialog>

                <!-- Booking Dialog -->
                <Dialog id="bookingDialog" title="Book a Helper" contentWidth="90%">
                    <VBox class="sapUiMediumMargin">
                        <Title text="{= 'Book ' + ${appData>/selectedProfile/name}}" level="H4" class="sapUiSmallMarginBottom"/>
                        <Label text="Service" required="true"/>
                        <Text text="{appData>/selectedProfile/serviceType}" class="sapUiTinyMarginBottom fontBold"/>
                        <Label text="Preferred Date" required="true"/>
                        <DatePicker id="bookingDate" value="{appData>/bookingForm/date}" valueFormat="yyyy-MM-dd" displayFormat="MMM dd, yyyy" width="100%" class="sapUiTinyMarginBottom"/>
                        <Label text="Preferred Time"/>
                        <Input id="bookingTime" value="{appData>/bookingForm/time}" placeholder="e.g. 09:00 AM" width="100%" class="sapUiTinyMarginBottom"/>
                        <Label text="Message to Helper"/>
                        <TextArea value="{appData>/bookingForm/message}" rows="3" width="100%" placeholder="Describe what you need…" class="sapUiTinyMarginBottom"/>
                    </VBox>
                    <beginButton>
                        <Button text="Send Booking Request" type="Emphasized" press="onConfirmBooking"/>
                    </beginButton>
                    <endButton>
                        <Button text="Cancel" press="onCloseBooking"/>
                    </endButton>
                </Dialog>

                <!-- Notifications Dialog -->
                <Dialog id="notificationsDialog" title="Notifications">
                    <VBox class="sapUiSmallMargin">
                        <HBox justifyContent="End" class="sapUiTinyMarginBottom">
                            <Button text="Mark all read" type="Transparent" press="onMarkAllRead"/>
                        </HBox>
                        <List id="notificationsList" items="{appData>/notifications}" noDataText="No notifications yet.">
                            <CustomListItem>
                                <VBox class="sapUiSmallMargin">
                                    <HBox justifyContent="SpaceBetween" alignItems="Center">
                                        <Title text="{appData>title}" level="H5"/>
                                        <core:HTML content="{= ${appData>is_read} ? '' : '&lt;span style=&quot;width:8px;height:8px;border-radius:50%;background:#3b82f6;display:inline-block&quot;&gt;&lt;/span&gt;'}"/>
                                    </HBox>
                                    <Text text="{appData>message}" class="smallText grayText"/>
                                    <Text text="{appData>created_at}" class="smallText grayText"/>
                                </VBox>
                            </CustomListItem>
                        </List>
                    </VBox>
                    <endButton>
                        <Button text="Close" press="onCloseNotifications"/>
                    </endButton>
                </Dialog>

                <!-- AI Chat Dialog — full screen on mobile -->
                <Dialog id="chatDialog" title="AI Chat" contentHeight="65vh" contentWidth="92%" verticalScrolling="false">
                    <!-- Messages fill available space; input pinned at bottom -->
                    <VBox height="100%" class="hhChatLayout">
                        <ScrollContainer id="chatScrollContainer" vertical="true" horizontal="false" class="hhChatMessages">
                            <core:HTML id="chatMessagesHtml" content="&lt;div&gt;&lt;/div&gt;"/>
                            <HBox id="chatTypingIndicator" visible="false" alignItems="Center" class="sapUiTinyMarginBegin sapUiTinyMarginBottom">
                                <BusyIndicator size="1rem" class="sapUiTinyMarginEnd"/>
                                <Text text="typing…" class="grayText smallText"/>
                            </HBox>
                        </ScrollContainer>
                        <!-- Quick reply chips -->
                        <HBox class="hhQuickReplies" wrap="Wrap">
                            <Button text="On my way 🚗"        type="Transparent" press="onQuickReply" class="hhQRChip sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
                            <Button text="I'm available ✅"    type="Transparent" press="onQuickReply" class="hhQRChip sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
                            <Button text="Can we reschedule? 📅" type="Transparent" press="onQuickReply" class="hhQRChip sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
                            <Button text="See you soon 👋"     type="Transparent" press="onQuickReply" class="hhQRChip sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
                            <Button text="All done ✔️"         type="Transparent" press="onQuickReply" class="hhQRChip sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
                        </HBox>
                        <HBox alignItems="Center" class="hhChatInputBar">
                            <Input id="chatInput" placeholder="Ask anything…" width="100%" submit="onChatSend"/>
                            <Button id="chatSendBtn" icon="sap-icon://paper-plane" type="Emphasized" press="onChatSend" class="sapUiTinyMarginBegin"/>
                        </HBox>
                    </VBox>

                    <endButton>
                        <Button text="Close" press="onCloseChat"/>
                    </endButton>
                </Dialog>

            </dependents>
        </Page>

    </NavContainer>


</mvc:View>
