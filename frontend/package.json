{
  "name": "helphub",
  "version": "0.0.1",
  "description": "HelpHub - Community Help Marketplace",
  "keywords": [
    "ui5",
    "openui5",
    "sapui5"
  ],
  "main": "www/index.html",
  "private": true,
  "scripts": {
    "// UI5 Dev & Run": "",
    "start": "fiori run --open \"test/flp.html#app-preview\"",
    "start-local": "fiori run --config ./ui5-local.yaml --open \"test/flp.html#app-preview\"",
    "start-noflp": "fiori run --open \"/index.html?sap-ui-xx-viewCache=false\"",
    "start-variants-management": "fiori run --open \"/preview.html#app-preview\"",
    "// Build & Deploy": "",
    "build": "ui5 build --config=ui5.yaml --clean-dest --dest dist",
    "deploy": "fiori verify",
    "deploy-config": "fiori add deploy-config",
    "// Testing": "",
    "unit-test": "fiori run --open \"test/unit/unitTests.qunit.html\"",
    "int-test": "fiori run --open \"test/integration/opaTests.qunit.html\"",
    "// Cordova Setup": "",
    "cordova:init": "cordova create mobile com.helphub.app HelpHub && cd mobile && cordova platform add android ios",
    "cordova:prepare": "cordova prepare",
    "// Cordova Build": "",
    "cordova:build": "cordova build",
    "cordova:build:android": "cordova build android",
    "cordova:build:ios": "cordova build ios",
    "// Cordova Run & Emulate": "",
    "cordova:run:android": "cordova run android",
    "cordova:run:ios": "cordova run ios",
    "cordova:emulate:android": "cordova emulate android",
    "cordova:emulate:ios": "cordova emulate ios",
    "// Cordova Plugins": "",
    "cordova:plugin:add": "cordova plugin add",
    "cordova:plugin:list": "cordova plugin list",
    "// Mobile Shortcuts": "",
    "mobile:dev": "npm run build && npm run cordova:prepare && npm run cordova:run:android",
    "mobile:build": "npm run build && npm run cordova:build",
    "// Maintenance": "",
    "clean": "rm -rf platforms plugins node_modules webapp/resources",
    "postinstall": "echo \"Run npm run cordova:init to initialize Cordova project\""
  },
  "dependencies": {
    "cordova-ios": "^7.0.1",
    "cordova-plugin-camera": "^7.0.0",
    "cordova-plugin-device": "^3.0.0",
    "cordova-plugin-dialogs": "^2.0.2",
    "cordova-plugin-file": "^8.1.3",
    "cordova-plugin-geolocation": "^4.1.0",
    "cordova-plugin-inappbrowser": "^5.0.0",
    "cordova-plugin-media": "^7.0.0",
    "cordova-plugin-network-information": "^3.0.0",
    "cordova-plugin-splashscreen": "^6.0.2",
    "cordova-plugin-statusbar": "^4.0.0",
    "cordova-plugin-vibration": "^3.1.1",
    "cordova-plugin-whitelist": "^1.3.5"
  },
  "devDependencies": {
    "@sap/ux-ui5-tooling": "1",
    "@ui5/cli": "^4.0.33",
    "cordova-android": "^14.0.1"
  },
  "cordova": {
    "platforms": [
      "android",
      "ios"
    ],
    "plugins": {
      "cordova-plugin-camera": {
        "ANDROIDX_CORE_VERSION": "1.6.+"
      },
      "cordova-plugin-device": {},
      "cordova-plugin-dialogs": {},
      "cordova-plugin-file": {
        "ANDROIDX_WEBKIT_VERSION": "1.4.0"
      },
      "cordova-plugin-geolocation": {
        "GPS_REQUIRED": "true"
      },
      "cordova-plugin-inappbrowser": {},
      "cordova-plugin-media": {},
      "cordova-plugin-network-information": {},
      "cordova-plugin-splashscreen": {},
      "cordova-plugin-statusbar": {},
      "cordova-plugin-vibration": {},
      "cordova-plugin-whitelist": {}
    }
  },
  "sapuxLayer": "CUSTOMER_BASE"
}