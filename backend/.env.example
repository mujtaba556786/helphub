# ─── Cloudinary (avatar/image storage — prevents photos being lost on redeploy) ──
# Free account at https://cloudinary.com → Dashboard → copy Cloud Name, API Key, API Secret
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Get this from https://console.cloud.google.com → APIs & Services → Credentials
# Create an OAuth 2.0 Client ID (Web application), add your domain to allowed origins
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ─── Facebook OAuth ───────────────────────────────────────────────────────────
# Get this from https://developers.facebook.com → My Apps → your app → Settings → Basic
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Long random secrets. REQUIRED in production (NODE_ENV=production) — the server
# refuses to boot without them so it never signs tokens with a known dev fallback.
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=helphub-change-this-secret-in-production
REFRESH_SECRET=helphub-change-this-refresh-secret-in-production

# ─── Demo / passwordless login (TESTING ONLY) ────────────────────────────────
# /api/auth/passwordless logs in any email with NO verification. Off by default.
# Set to true ONLY in local/testing environments — never in production.
ALLOW_DEMO_LOGIN=false

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=8889
DB_USER=root
DB_PASSWORD=root
DB_NAME=servicelink_db
