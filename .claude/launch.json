{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "frontend/webapp"],
      "port": 8080,
      "autoPort": false
    },
    {
      "name": "backend",
      "runtimeExecutable": "node",
      "runtimeArgs": ["server.js"],
      "cwd": "${workspaceFolder}/backend",
      "port": 3000
    }
  ]
}
